{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "notex",
  "version": "1.8.8",
  "identifier": "com.theo.notex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "notex",
        "width": 1000,
        "height": 550
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "235f3dfd-b4b1-5e72-8874-9bc080d859fa"
      }
    },
    "fileAssociations": [
      {
        "ext": ["txt", "md", "markdown", "json", "html", "css", "js", "ts"],
        "name": "Text Document",
        "role": "Editor",
        "mimeType": "text/plain"
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["notex"]
      }
    }
  }
}